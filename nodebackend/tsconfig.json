{
  "compilerOptions": {
    "target": "es2015",
    "module": "es2015",
    // "moduleResolution": "node",//"NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}


